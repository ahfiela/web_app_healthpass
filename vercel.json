{
  "version": 2,
  "framework": null,
  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.7.3",
      "config": {
        "maxDuration": 30,
        "includeFiles": [
          "config/**",
          "resources/views/**",
          "routes/**"
        ]
      }
    }
  },
  "routes": [
    {
      "src": "/assets/(.*)",
      "dest": "/public/assets/$1"
    },
    {
      "src": "/((?!public/).*)",
      "dest": "/api/index.php"
    }
  ]
}
